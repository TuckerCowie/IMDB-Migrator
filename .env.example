# IMDB Migration Credentials
# Copy this file to .env and fill in your actual credentials

# Source account (the account you're migrating FROM)
IMDB_SOURCE_EMAIL=your.source@email.com
IMDB_SOURCE_PASSWORD=your_source_password

# Destination account (the account you're migrating TO)
IMDB_DEST_EMAIL=your.destination@email.com
IMDB_DEST_PASSWORD=your_destination_password